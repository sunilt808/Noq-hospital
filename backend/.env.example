# Backend environment variables (Railway/local)

# JWT signing secret (set a long random value)
JWT_SECRET=replace_with_strong_secret

# Optional password salt override
PASSWORD_SALT=replace_with_random_salt

# If using JSON credentials via file path in local dev, keep file out of git.
# In Railway, prefer secret variables / mounted secret file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
